---
import '../styles/global.css';
import Sidebar from '../components/Sidebar';

interface Props {
    title?: string;
    description?: string;
}

const {
    title = 'Parcello',
    description = 'Self-hostable package tracking web app',
} = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <title>{title}</title>
    </head>
    <body>
        <div class="flex h-screen overflow-hidden">
            <!-- Sidebar -->
            <Sidebar client:load />

            <!-- Main content with gradient background (light mode only) -->
            <main class="flex-1 overflow-y-auto lg:ml-0 main-gradient">
                <div class="container mx-auto px-4 py-2 lg:px-8 lg:py-12">
                    <slot />
                </div>
            </main>
        </div>
    </body>
</html>
